# 845 Premium Detailing - environment variable NAMES (no real values here).
#
# The PUBLIC static site (GitHub Pages) needs NONE of these - it is static
# files plus the Google Apps Script booking backend. These apply only to the
# LOCAL Node backend (server.js), which is not deployed publicly.

# Admin password for the local Node admin (server.js, port 3001).
# If unset on first boot, a random password is generated and printed once.
ADMIN_PASSWORD=

# Ports for the local Node servers.
PORT=3000
ADMIN_PORT=3001

# Google Calendar via service account - LOCAL Node backend only.
# (The public site books through Apps Script, which uses your Google login,
#  not these.) The key file itself is gitignored and never committed.
GOOGLE_SERVICE_ACCOUNT_FILE=./google-service-account.json
GOOGLE_CALENDAR_ID=

# --- Not .env, but related secrets that live OUTSIDE this repo ---
# Apps Script "Script Properties" (set in the Apps Script project, not here):
#   TURNSTILE_SECRET   - Cloudflare Turnstile secret key (optional bot protection)
# Hosted admin (/manage/) login:
#   A GitHub fine-grained PAT (Contents: Read and write on this repo), entered
#   in the browser at sign-in and stored only in localStorage - never committed.
